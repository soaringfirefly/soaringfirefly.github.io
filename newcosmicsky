<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <title>Alba Cosmica: Cielo Stellato Completo</title>
  <style>
    body {
      margin: 0;
      height: 100vh;
      /* Sfondo che schiarisce verso l'orizzonte */
      background: linear-gradient(to bottom, #02050f 0%, #1a0a2e 60%, #2e0a1f 100%);
      overflow: hidden;
      display: flex;
      justify-content: center;
      align-items: flex-end;
      position: relative;
    }

    /* CIELO STELLATO RICCO CON COSTELLAZIONI */
    .stars-sky {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 65%;
      /* Mix di stelle sparse (1px) e punti più luminosi per le costellazioni (1.5px) */
      background-image: 
        /* --- STELLE SPARSE IN ALTO --- */
        radial-gradient(1px 1px at 5% 10%, #fff 100%, transparent),
        radial-gradient(1.2px 1.2px at 15% 25%, #fff 100%, transparent),
        radial-gradient(1px 1px at 25% 15%, #fff 100%, transparent),
        radial-gradient(1px 1px at 35% 5%, #fff 100%, transparent),
        radial-gradient(1.2px 1.2px at 45% 20%, #fff 100%, transparent),
        radial-gradient(1px 1px at 60% 12%, #fff 100%, transparent),
        radial-gradient(1.2px 1.2px at 75% 8%, #fff 100%, transparent),
        radial-gradient(1px 1px at 85% 18%, #fff 100%, transparent),
        radial-gradient(1px 1px at 95% 10%, #fff 100%, transparent),
        radial-gradient(1.2px 1.2px at 50% 30%, #fff 100%, transparent),
        radial-gradient(1px 1px at 10% 40%, #fff 100%, transparent),
        radial-gradient(1.2px 1.2px at 90% 35%, #fff 100%, transparent),

        /* --- COSTELLAZIONE 1 (Sinistra) --- */
        radial-gradient(1.5px 1.5px at 10% 20%, #fff 100%, transparent),
        radial-gradient(1.5px 1.5px at 12% 23%, #fff 100%, transparent),
        radial-gradient(1.5px 1.5px at 15% 22%, #fff 100%, transparent),
        radial-gradient(1.5px 1.5px at 17% 26%, #fff 100%, transparent),

        /* --- COSTELLAZIONE 2 (Destra) --- */
        radial-gradient(1.5px 1.5px at 80% 15%, #fff 100%, transparent),
        radial-gradient(1.5px 1.5px at 83% 12%, #fff 100%, transparent),
        radial-gradient(1.5px 1.5px at 86% 15%, #fff 100%, transparent),
        radial-gradient(1.5px 1.5px at 83% 18%, #fff 100%, transparent);

      background-size: 500px 500px; /* Ripetizione ampia per densità */
      filter: drop-shadow(0 0 2px white);
      opacity: 0.6;
      animation: stars-fade 11s ease-in-out infinite;
      pointer-events: none;
    }

    /* IL SOLE / BAGLIORE ALL'ORIZZONTE */
    .horizon-glow {
      position: absolute;
      width: 250vw;
      height: 180vh;
      bottom: -90vh;
      background: radial-gradient(circle at center, 
        #ffffff 0%,           
        #ffcc00 4%,           /* Giallo ulteriormente ridotto */
        #ff6600 18%,          
        #660099 45%,          
        #050a1f 75%,          
        transparent 100%
      );
      filter: blur(100px); 
      opacity: 0.7;
      animation: seamless-sunrise 11s ease-in-out infinite;
      z-index: 1;
    }

    /* Le stelle spariscono totalmente al 50% (picco alba) */
    @keyframes stars-fade {
      0%, 100% { opacity: 0.7; }
      50% { opacity: 0.0; } 
    }

    /* Respiro del sole */
    @keyframes seamless-sunrise {
      0%, 100% { 
        transform: scale(1) translateY(40px); 
        opacity: 0.4;
        filter: blur(120px);
      }
      50% { 
        transform: scale(1.3) translateY(-90px); 
        opacity: 0.9; 
        filter: blur(80px);
      }
    }
  </style>
</head>
<body>
  <div class="stars-sky"></div>
  <div class="horizon-glow"></div>
</body>
</html>
